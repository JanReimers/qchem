{
    "files.exclude": {
    "**/.bin": true,
    "**/.dd": true,
    "**/.ddi": true,
    "**/.ddi.d": true,
    "**/.gcm": true,
    "**/.pcm": true,
    "**/.json": true,
    "**/.ninja": true,
    "${workspaceFolder}/submodules": true,
    "${workspaceFolder}/build": true,
    "/bin": true,
    "/boot": true,
    "/cdrom": true,
    "/dev": true,
    "/proc": true,
    "/etc":true
    },
    "C_Cpp.files.exclude": {
        "/": true,
        "**/.vscode": true,
        "**/.vs": true,
        "**/.git": true,
        "${workspaceFolder}/submodules": true,
        "${workspaceFolder}/build": true
    },
    
        "git.ignoredRepositories": [
        "submodules/wignerSymbols",
        "submodules/blaze",
        "submodules/BSplinebasis",
        "submodules/tabulate",
        "submodules/googletest",
        "submodules/json",
        "submodules/libxc",

        ]
    ,
    "C_Cpp.exclusionPolicy": "checkFilesAndFolders",
    "files.associations": {
        "*.C": "cpp",
        "*.H": "cpp",
        "*.Ci": "cpp",
        "iosfwd": "cpp",
        "new": "cpp",
        "cctype": "cpp",
        "clocale": "cpp",
        "cmath": "cpp",
        "cstdarg": "cpp",
        "cstddef": "cpp",
        "cstdio": "cpp",
        "cstdlib": "cpp",
        "cstring": "cpp",
        "ctime": "cpp",
        "cwchar": "cpp",
        "cwctype": "cpp",
        "any": "cpp",
        "array": "cpp",
        "atomic": "cpp",
        "bit": "cpp",
        "*.tcc": "cpp",
        "compare": "cpp",
        "complex": "cpp",
        "concepts": "cpp",
        "condition_variable": "cpp",
        "cstdint": "cpp",
        "deque": "cpp",
        "map": "cpp",
        "set": "cpp",
        "string": "cpp",
        "unordered_map": "cpp",
        "vector": "cpp",
        "exception": "cpp",
        "algorithm": "cpp",
        "functional": "cpp",
        "iterator": "cpp",
        "memory": "cpp",
        "memory_resource": "cpp",
        "numeric": "cpp",
        "optional": "cpp",
        "random": "cpp",
        "ratio": "cpp",
        "source_location": "cpp",
        "string_view": "cpp",
        "system_error": "cpp",
        "tuple": "cpp",
        "type_traits": "cpp",
        "utility": "cpp",
        "fstream": "cpp",
        "initializer_list": "cpp",
        "iomanip": "cpp",
        "iostream": "cpp",
        "istream": "cpp",
        "limits": "cpp",
        "mutex": "cpp",
        "numbers": "cpp",
        "ostream": "cpp",
        "semaphore": "cpp",
        "span": "cpp",
        "sstream": "cpp",
        "stdexcept": "cpp",
        "stop_token": "cpp",
        "streambuf": "cpp",
        "thread": "cpp",
        "cinttypes": "cpp",
        "typeinfo": "cpp",
        "variant": "cpp",
        "irrep_bs,h": "cpp",
        "hf_ibs_h": "cpp",
        "charconv": "cpp",
        "list": "cpp",
        "format": "cpp",
        "valarray": "cpp",
        "text_encoding": "cpp",
        "unordered_set": "cpp",
        "typeindex": "cpp",
        "*.ipp": "cpp",
        "strstream": "cpp",
        "cfenv": "cpp",
        "future": "cpp",
        "stdfloat": "cpp",
        "chrono": "cpp",
        "cassert": "cpp",
        "csignal": "cpp",
