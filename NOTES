            int partial_Sum, total_Sum;
            #pragma omp parallel private(partial_Sum) shared(total_Sum)
            {
                partial_Sum = 0;
                total_Sum = 0;

                #pragma omp for
                for(int i = 1; i <= 1000; i++){
                    partial_Sum += i;
                }

                //Create thread safe region.
                #pragma omp critical
                {
                    //add each threads partial sum to the total sum
                    total_Sum += partial_Sum;
                }
            }
